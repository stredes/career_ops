  text-transform: none;
  font-size: 0.9rem;
  line-height: 16px;
  font-family: -apple-system, system-ui, sans-serif;
}
.job .meta {
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
  display: block;
  color: #5f5d5d;
  margin-bottom: 0px;
  margin-top: 0;
  font-weight: 400;
  text-transform: none;
  font-size: 0.7rem;
  line-height: 17px;
  margin-left: 58px;
  font-family: -apple-system, system-ui, sans-serif;
}
.job .description {
  margin-bottom: 0;
