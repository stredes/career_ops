/* box general (titulos, textos etc) */
.box {
  background: #fff;
  /* box-shadow: 0 0 0 1px rgba(0,0,0,.1), 0 2px 3px rgba(0,0,0,.2); */
  transition: box-shadow 83ms;
  /*border: 1px solid;
    border-color: #e5e6e9 #dfe0e4 #d0d1d5;*/
  border-radius: 0 0 3px 3px;
  /*border-radius: 3px;*/
  margin-bottom: 7px;
  padding: 10px;
