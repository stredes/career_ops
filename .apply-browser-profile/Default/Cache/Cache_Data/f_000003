/* Pagination */
.pagination {
  display: inline-block;
  overflow: hidden;
  margin: 0;
  padding: 0;
  list-style: none;
  background: #ffffff;
}

.pagination:before,
.pagination:after {
  display: table;
  content: " ";
}

.pagination:after {
  clear: both;
}

.pagination > li {
  float: left;
}

.pagination > li:last-child {
  border-right: 0;
}

.pagination > li > a,
.pagination > li > b {
  display: block;
  width: 40px;
  height: 38px;
  color: inherit;
  text-align: center;
  text-decoration: none;
  line-height: 38px;
  padding-top: 0;
  position: relative;
}

.pagination > li > b {
  color: #fff;
  background: #1f5372;
}

.pagination > li > a:hover {
  color: #fff;
