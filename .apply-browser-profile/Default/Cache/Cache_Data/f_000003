  overflow: hidden;
  -webkit-transition: all 0.15s ease-in;
  -moz-transition: all 0.15s ease-in;
  -o-transition: all 0.15s ease-in;
  transition: all 0.15s ease-in;
}
.job .thumb {
  display: block;
  background-size: 90% !important;
  width: 48px;
  height: 48px;
  overflow: hidden;
  padding: 3px;
  float: left;
  margin-right: 10px;
}
.job .thumb span {
  display: block;
  text-align: center;
  line-height: 40px;
  font-weight: normal;
  font-size: 26px;
  color: #fff;
}
.job .title {
