}

.profile .profile-header a .profile-name {
  text-align: center;
  margin: 10px 10px 5px;
  font-weight: bold;
  color: #000;
}

.profile .profile-header a:hover {
  text-decoration: none;
}

.profile .profile-header .profile-job {
  text-align: center;
  margin: 0px 10px 10px;
